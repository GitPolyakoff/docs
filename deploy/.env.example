# Copy this file to .env in the same directory as docker-compose.yml and fill in the secret.
# Generate one with: openssl rand -hex 32
WEBHOOK_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET

# Optional: Truckline public API host (no /api/v1 — nginx adds it on api.* subdomains)
# TRUCKLINE_API_URL=https://api.trucklinemp.com
