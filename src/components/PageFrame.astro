---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageFrame.astro';
import { getCollection } from 'astro:content';

interface AstroProps extends Props {
	'client:load'?: boolean;
}

const props = Astro.props as AstroProps;
const entry = (props as any).entry;
const lastUpdated = entry?.data?.lastUpdated || null;
const locale = entry?.collection || 'root';
const slug = entry?.slug || '';

// Check if translation is outdated
let isOutdated = false;
if (locale !== 'root' && slug) {
	try {
		const allDocs = await getCollection('docs');
		const englishDoc = allDocs.find(doc => doc.slug === slug && doc.id.startsWith('docs/') && !doc.id.includes('/'));
		const translatedDoc = allDocs.find(doc => doc.slug === slug && doc.id.startsWith(`docs/${locale}/`));

		if (englishDoc && translatedDoc) {
			const englishDate = new Date(englishDoc.data.lastUpdated || '2026-01-01').getTime();
			const translatedDate = new Date(translatedDoc.data.lastUpdated || '2026-01-01').getTime();
			isOutdated = englishDate - translatedDate > 86400000;
		}
	} catch (e) {
		// Silently fail
	}
}
---

<Default {...props}>
	{isOutdated && (
		<div style="background-color: var(--sl-color-yellow-low); border: 1px solid var(--sl-color-yellow); border-radius: 0.5rem; padding: 1rem; margin-bottom: 1.5rem; font-size: var(--sl-text-sm);">
			<p style="margin: 0; color: var(--sl-color-text-accent);">
				This translation may be outdated. <a href={`/${slug}`} style="color: var(--sl-color-text-accent); text-decoration: underline;">View the English version</a>
			</p>
		</div>
	)}
	<slot />
	{lastUpdated && (
		<div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--sl-color-hairline); font-size: var(--sl-text-xs); color: var(--sl-color-gray-3);">
			Last updated: {new Date(lastUpdated).toLocaleDateString()}
		</div>
	)}
</Default>
